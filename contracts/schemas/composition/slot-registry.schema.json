{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://erganis.dev/schemas/composition/slot-registry.schema.json",
  "title": "ErganisSlotRegistry",
  "description": "Platform layout slots — Core C10 GET /composition/slots response shape.",
  "type": "object",
  "required": ["slots"],
  "properties": {
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "accepts": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional component kind hints (nav, widget, form)"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
