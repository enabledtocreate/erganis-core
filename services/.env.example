# Services Environment Variables
# Copy to .env and fill in values

# Database (matches infrastructure/docker/docker-compose.yml defaults)
# Use 127.0.0.1 on Windows if localhost fails (WSL ::1 vs Docker IPv4).
DATABASE_URL=postgresql://erganis:dev_password@127.0.0.1:5432/erganis

# Local file storage (required for FileStore in later phases)
ERGANIS_DATA_ROOT=./data

# API
API_PORT=5000
API_HOST=0.0.0.0

# Logging (Nest console: error | warn | info | debug)
LOG_LEVEL=info

# Environment
NODE_ENV=development

# Auth (Phase 1)
JWT_SECRET=dev-only-change-in-production
SESSION_COOKIE_NAME=erganis_session
SESSION_TTL_SECONDS=86400
JWT_TTL_SECONDS=3600
OIDC_CALLBACK_BASE_URL=http://localhost:5000
AUTH_LOCAL_ENABLED=true
AUTH_OIDC_MOCK=true
MIGRATIONS_DIR=../data/migrations
RUN_MIGRATIONS_ON_START=true

# Modules (Phase 2)
MODULES_ROOT=../../studio/modules
# Optional extra module roots (comma-separated). Developer module is NOT shipped by default.
MODULES_EXTRA_ROOTS=../../developer
CORS_ORIGINS=http://localhost:3000

# Orchestrator (C3)
ENTITY_LOCK_TTL_SECONDS=300

# Platform jobs & outbox (C9)
JOBS_ENABLED=true
PGBOSS_SCHEMA=pgboss
OUTBOX_ENABLED=true
OUTBOX_POLL_INTERVAL_MS=2000
OUTBOX_BATCH_SIZE=25
# REDIS_URL=redis://localhost:6379
