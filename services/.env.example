# Services Environment Variables
# Copy to .env and fill in values

# Database (matches infrastructure/docker/docker-compose.yml defaults)
DATABASE_URL=postgresql://erganis:dev_password@localhost:5432/erganis

# Local file storage (required for FileStore in later phases)
ERGANIS_DATA_ROOT=./data

# API
API_PORT=5000
API_HOST=0.0.0.0

# Logging
LOG_LEVEL=info

# Environment
NODE_ENV=development

# Redis — optional, not required for v1 (pg-boss uses PostgreSQL)
# REDIS_URL=redis://localhost:6379
